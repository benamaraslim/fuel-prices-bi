        "fromColumn": "iso3",
        "toTable": "SubsidyTracker",
        "toColumn": "iso3",
        "crossFilteringBehavior": "bothDirections"
      },
      {
        "name": "Rel_GlobalFuelPrices_FuelTaxComparison",
        "fromTable": "GlobalFuelPrices",
        "fromColumn": "country",
        "toTable": "FuelTaxComparison",
        "toColumn": "country",
        "crossFilteringBehavior": "bothDirections"
      },
      {
        "name": "Rel_PriceTrendMonthly_GlobalFuelPrices",
        "fromTable": "PriceTrendMonthly",
        "fromColumn": "country",
        "toTable": "GlobalFuelPrices",
        "toColumn": "country"
      }
    ],
